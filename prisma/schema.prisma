generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model actividades {
  id             Int         @id @default(autoincrement())
  modulo_id      Int
  nombre         String      @db.VarChar(150)
  descripcion    String?     @db.Text
  orden          Int         @default(1)
  activo         Boolean?    @default(true)
  fecha_creacion DateTime?   @default(now()) @db.Timestamp(0)
  modulos        modulos     @relation(fields: [modulo_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "actividades_ibfk_1")
  preguntas      preguntas[]

  @@index([modulo_id], map: "modulo_id")
}

model cursos {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(150)
  descripcion    String?   @db.Text
  duracion_horas Int?
  activo         Boolean?  @default(true)
  fecha_creacion DateTime? @default(now()) @db.Timestamp(0)
  modulos        modulos[]
}

model modulos {
  id             Int           @id @default(autoincrement())
  curso_id       Int
  nombre         String        @db.VarChar(150)
  descripcion    String?       @db.Text
  orden          Int
  duracion_horas Int?
  actividades    actividades[]
  cursos         cursos        @relation(fields: [curso_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "modulos_ibfk_1")

  @@index([curso_id], map: "curso_id")
}

model preguntas {
  id           Int         @id @default(autoincrement())
  actividad_id Int
  pregunta     String      @db.Text
  orden        Int         @default(1)
  actividades  actividades @relation(fields: [actividad_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "preguntas_ibfk_1")

  @@index([actividad_id], map: "actividad_id")
}
