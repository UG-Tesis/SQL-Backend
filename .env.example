PORT=3000

# Railway (desde tu Mac usa el TCP Proxy)
MYSQL_HOST=thomas.proxy.rlwy.net
MYSQL_PORT=16835
MYSQL_USER=root
MYSQL_PASSWORD=tu_password_railway
MYSQL_DATABASE=tesis_sql
MYSQL_SANDBOX_DATABASE=tesis_sandbox
MYSQL_SSL=true
MYSQL_CONNECTION_LIMIT=10
DATABASE_URL="mysql://root:tu_password_railway@thomas.proxy.rlwy.net:16835/tesis_sql"

# --- Migraciones tesis_sql (Prisma) ---
# Crear migración:     npm run prisma:migrate:dev -- --name descripcion
# Aplicar en Railway:  npm run prisma:migrate:deploy
# Ver estado:          npm run prisma:migrate:status

# --- Migraciones tesis_sandbox (SQL manual) ---
# Nueva migración en scripts/sandbox-migrations/
# Aplicar:             ./scripts/apply-sandbox-migration.sh 001_initial.sql

# Railway (servicio desplegado — variables internas)
# MYSQL_HOST=${{MySQL.MYSQLHOST}}
# MYSQL_PORT=${{MySQL.MYSQLPORT}}
# MYSQL_USER=${{MySQL.MYSQLUSER}}
# MYSQL_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# MYSQL_DATABASE=tesis_sql
# MYSQL_SANDBOX_DATABASE=tesis_sandbox
# MYSQL_SSL=true
# DATABASE_URL=mysql://${{MySQL.MYSQLUSER}}:${{MySQL.MYSQLPASSWORD}}@${{MySQL.MYSQLHOST}}:${{MySQL.MYSQLPORT}}/tesis_sql
# (DATABASE_URL es obligatoria para prisma migrate deploy en cada deploy)
