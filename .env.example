PORT=3000

# Railway (desde tu Mac usa el TCP Proxy)
MYSQL_HOST=thomas.proxy.rlwy.net
MYSQL_PORT=16835
MYSQL_USER=root
MYSQL_PASSWORD=tu_password_railway
MYSQL_DATABASE=tesis_sql
MYSQL_SANDBOX_DATABASE=tesis_sandbox
# Usuario MySQL restringido para práctica (DML sin DDL ni DROP DATABASE)
MYSQL_SANDBOX_PLAYER_USER=tesis_sandbox_player
MYSQL_SANDBOX_PLAYER_PASSWORD=genera_una_clave_segura
MYSQL_MISTERIO_DATABASE=tesis_misterio
# Usuario MySQL restringido para consultas del juego (SELECT en tablas del caso + INSERT en solucion)
MYSQL_MISTERIO_PLAYER_USER=tesis_misterio_player
MYSQL_MISTERIO_PLAYER_PASSWORD=genera_una_clave_segura
MYSQL_ISLAND_DATABASE=tesis_island
# TTL de sesiones huérfanas de SQL Island (ms). Cada jugador usa un clon tesis_island_<sessionId>
ISLAND_SESSION_TTL_MS=7200000
MYSQL_SSL=true
# Necesario en false al conectar desde tu Mac al TCP Proxy de Railway
MYSQL_SSL_REJECT_UNAUTHORIZED=false
MYSQL_CONNECT_TIMEOUT=30000
MYSQL_CONNECTION_LIMIT=10
DATABASE_URL="mysql://root:tu_password_railway@thomas.proxy.rlwy.net:16835/tesis_sql"

# --- Migraciones tesis_sql (Prisma) ---
# Crear migración:     npm run prisma:migrate:dev -- --name descripcion
# Aplicar en Railway:  npm run prisma:migrate:deploy
# Ver estado:          npm run prisma:migrate:status

# --- Migraciones tesis_sandbox (SQL manual) ---
# Nueva migración en scripts/sandbox-migrations/
# Aplicar:             ./scripts/apply-sandbox-migration.sh 001_initial.sql
# Permisos restringidos (DML sin DDL): ./scripts/apply-sandbox-privileges.sh

# --- Base tesis_misterio (juego SQL Murder Mystery en español) ---
# Esquema: scripts/misterio-migrations/001_schema.sql
# Datos:   scripts/seed_misterio_data.py (desde scripts/data/sql-murder-mystery.db)
# Aplicar: ./scripts/apply-misterio-migration.sh
# Permisos restringidos (SELECT sin solucion + INSERT en solucion): ./scripts/apply-misterio-privileges.sh

# --- Base tesis_island (juego SQL Island en español) ---
# Plantilla compartida. Cada partida clona esta base a tesis_island_<sessionId>.
# Esquema: scripts/island-migrations/001_schema.sql
# Aplicar: ./scripts/apply-island-migration.sh

# Railway (servicio desplegado — variables internas)
# MYSQL_HOST=${{MySQL.MYSQLHOST}}
# MYSQL_PORT=${{MySQL.MYSQLPORT}}
# MYSQL_USER=${{MySQL.MYSQLUSER}}
# MYSQL_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# MYSQL_DATABASE=tesis_sql
# MYSQL_SANDBOX_DATABASE=tesis_sandbox
# MYSQL_SSL=true
# DATABASE_URL=mysql://${{MySQL.MYSQLUSER}}:${{MySQL.MYSQLPASSWORD}}@${{MySQL.MYSQLHOST}}:${{MySQL.MYSQLPORT}}/tesis_sql
# (DATABASE_URL es obligatoria para prisma migrate deploy en cada deploy)
